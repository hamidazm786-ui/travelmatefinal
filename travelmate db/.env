# ============================================================
#  TravelMate Backend — Environment Variables
#  Copy this to .env and fill in your real values.
#  NEVER commit .env to version control.
# ============================================================

# ── Server ─────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000,http://127.0.0.1:3000

# ── PostgreSQL Database ────────────────────────────────────
# Option A: Use Neon (FREE cloud PostgreSQL — recommended, no install needed)
# Sign up at neon.tech → create project → copy the connection string
DATABASE_URL=postgresql+asyncpg://username:password@host/dbname

# Option B: Local PostgreSQL (if you install it locally)
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/travelmate

# ── Auth / JWT ─────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_secret_key_at_least_64_chars_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Groq (Primary LLM — Free) ──────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama3-70b-8192
GROQ_FALLBACK_MODEL=mixtral-8x7b-32768

# ── Google Gemini (Fallback LLM) ───────────────────────────
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Tavily Search ───────────────────────────────────────────
TAVILY_API_KEY=tvly-your_tavily_key_here
TAVILY_MAX_RESULTS=8
TAVILY_SEARCH_DEPTH=advanced

# ── File Upload ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,txt,docx,png,jpg,jpeg

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
